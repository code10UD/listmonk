# Dockerfile complet pour Listmonk avec extension géographique française
# Cette version compile le frontend ET le backend

# Stage 1: Build frontend
FROM node:18-alpine AS frontend-builder

WORKDIR /src

# Copier les fichiers package.json
COPY frontend/package.json frontend/yarn.lock ./

# Installer les dépendances
RUN yarn install --frozen-lockfile

# Copier le code source frontend
COPY frontend/ ./

# Construire le frontend
RUN yarn build

# Stage 2: Build backend
FROM golang:1.23-alpine AS backend-builder

# Installer les dépendances de build
RUN apk add --no-cache git make build-base ca-certificates

# Définir le répertoire de travail
WORKDIR /src

# Copier les fichiers de dépendances Go
COPY go.mod go.sum ./
RUN go mod download

# Copier les fichiers source
COPY cmd/ ./cmd/
COPY internal/ ./internal/
COPY models/ ./models/
COPY queries.sql ./
COPY schema.sql ./
COPY Makefile ./
COPY static/ ./static/
COPY i18n/ ./i18n/
COPY config.toml.sample ./config.toml.sample
COPY permissions.json ./permissions.json
COPY frontend/ ./frontend/

# Copier les fichiers frontend compilés au bon endroit
COPY --from=frontend-builder /src/dist ./frontend/dist

# Installer stuffbin pour intégrer les fichiers statiques
RUN go install github.com/knadh/stuffbin/...

# Construire l'application Go avec les fichiers statiques intégrés
RUN make dist

# Stage 3: Image finale
FROM alpine:latest

# Installer les dépendances runtime
RUN apk add --no-cache ca-certificates tzdata postgresql-client curl

# Créer l'utilisateur listmonk
RUN addgroup -g 1000 listmonk && \
    adduser -D -s /bin/sh -u 1000 -G listmonk listmonk

# Créer les répertoires nécessaires
RUN mkdir -p /listmonk/uploads /listmonk/static /listmonk/i18n /listmonk/scripts /listmonk/demo && \
    chown -R listmonk:listmonk /listmonk

# Copier le binaire depuis le builder
COPY --from=backend-builder /src/listmonk /listmonk/listmonk
COPY --from=backend-builder /src/config.toml.sample /listmonk/config.toml.sample

# Copier les scripts d'initialisation
COPY docker/scripts/ /listmonk/scripts/
RUN chmod +x /listmonk/scripts/*.sh

# Copier les fichiers de démonstration
COPY demo_geo_data.csv /listmonk/demo/
COPY demo_geographic_queries.sql /listmonk/demo/
COPY test_geo_data.csv /listmonk/demo/

# Point d'entrée avec initialisation géographique
COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# Définir le répertoire de travail
WORKDIR /listmonk

# Changer vers l'utilisateur listmonk
USER listmonk

# Exposer le port
EXPOSE 9000

# Point d'entrée
ENTRYPOINT ["/entrypoint.sh"]
CMD ["./listmonk"]